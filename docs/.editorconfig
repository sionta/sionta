root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

# Unix-style newlines with a newline ending every file
end_of_line = lf
insert_final_newline = true

[*.{js,css,scss}]
quote_type = single

[*.{bat,cmd,ps1,psd1,psm1}]
indent_size = 4
end_of_line = crlf
indent_style = space

[*.{yml,yaml}]
quote_type = double

[*.md]
trim_trailing_whitespace = false
